
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Company documents - users can only access their own company
    match /companies/{companyId} {
      allow read, write: if request.auth != null && 
        request.auth.uid in resource.data.userIds;
    }
    
    // Clients - users can only access clients for their company
    match /clients/{clientId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.userIds;
    }
    
    // Suppliers - users can only access suppliers for their company
    match /suppliers/{supplierId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.userIds;
    }
    
    // Invoices - users can only access invoices for their company
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.userIds;
    }
    
    // Payments - users can only access payments for their company
    match /payments/{paymentId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.userIds;
    }
    
    // Expenses - users can only access expenses for their company
    match /expenses/{expenseId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.userIds;
    }
    
    // GST Returns - users can only access GST returns for their company
    match /gst_returns/{returnId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.userIds;
    }
    
    // TDS Records - users can only access TDS records for their company
    match /tds_records/{recordId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.userIds;
    }
  }
}
