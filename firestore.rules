
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function to check if user belongs to a company
    function belongsToCompany(companyId) {
      return getUserData().companyId == companyId;
    }

    // Helper function to check if user is company admin with valid company
    function isCompanyAdmin() {
      return request.auth != null &&
        getUserData().role == 'company_admin' &&
        getUserData().companyId != null;
    }

    // Helper function to check if user is super admin
    function isSuperAdmin() {
      return request.auth != null &&
        getUserData().role == 'super_admin';
    }

    // Helper function to check if user is an employee
    function isEmployee() {
      return request.auth != null &&
        getUserData().role == 'employee' &&
        getUserData().companyId != null;
    }

    // Helper function to check if user is company admin or employee from same company
    function isCompanyMember() {
      return isCompanyAdmin() || isEmployee();
    }

    // USERS: each user can access their own document, company admins can access employees in their company
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Company admin can read/update employees in their company
      allow read, update: if isCompanyAdmin() && belongsToCompany(resource.data.companyId);
      
      // Super admin can read/update any user document
      allow read, update: if isSuperAdmin();
    }

    // COMPANIES: company admins can only access their own company
    match /companies/{companyId} {
      // Company admin can read/write their own company
      allow read, write: if isCompanyAdmin() && belongsToCompany(companyId);
      
      // Employees can read their company information
      allow read: if isEmployee() && belongsToCompany(companyId);
      
      // Super admin can access all companies
      allow read, write: if isSuperAdmin();
      
      // Allow company creation during signup - company ID must match user ID
      allow create: if request.auth != null &&
        getUserData().role == 'company_admin' &&
        companyId == request.auth.uid;
    }

    // CLIENTS: accessible by company members (admin and employees)
    match /clients/{clientId} {
      // For existing documents, check if the document's companyId matches user's companyId
      allow read: if isCompanyMember() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Only company admins can write/create clients
      allow write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      // Super admin has full access
      allow read, write: if isSuperAdmin();
    }

    // INVOICES: accessible by company members (admin and employees)
    match /invoices/{invoiceId} {
      allow read: if isCompanyMember() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Only company admins can write/create invoices
      allow write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      allow read, write: if isSuperAdmin();
    }

    // PAYMENTS: accessible by company members (admin and employees)
    match /payments/{paymentId} {
      allow read: if isCompanyMember() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Only company admins can write/create payments
      allow write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      allow read, write: if isSuperAdmin();
    }

    // EXPENSES: accessible by company members (admin and employees)
    match /expenses/{expenseId} {
      allow read: if isCompanyMember() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Only company admins can write/create expenses
      allow write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      allow read, write: if isSuperAdmin();
    }

    // PURCHASES: accessible by company members (admin and employees)
    match /purchases/{purchaseId} {
      allow read: if isCompanyMember() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Only company admins can write/create purchases
      allow write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      allow read, write: if isSuperAdmin();
    }

    // INVENTORY: accessible by company members (admin and employees)
    match /inventory/{inventoryId} {
      allow read: if isCompanyMember() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Only company admins can write/create inventory
      allow write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      allow read, write: if isSuperAdmin();
    }

    // TDS RECORDS: accessible by company members (admin and employees)
    match /tds_records/{tdsId} {
      allow read: if isCompanyMember() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Only company admins can write/create TDS records
      allow write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      allow read, write: if isSuperAdmin();
    }

    // SUPPLIERS: accessible by company members (admin and employees)
    match /suppliers/{supplierId} {
      allow read: if isCompanyMember() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Only company admins can write/create suppliers
      allow write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      allow read, write: if isSuperAdmin();
    }

    // EMPLOYEES: accessible by company admins and employees can read their own data
    match /employees/{employeeId} {
      // Company admins can manage all employees in their company
      allow read, write: if isCompanyAdmin() && 
        (resource == null || resource.data.companyId == getUserData().companyId);
      
      // Employees can read their own employee record
      allow read: if isEmployee() && 
        resource.data.userId == request.auth.uid;
      
      allow create: if isCompanyAdmin() &&
        request.resource.data.companyId == getUserData().companyId;
      
      allow read, write: if isSuperAdmin();
    }
  }
}
