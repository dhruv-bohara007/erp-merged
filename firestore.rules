
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to users collection for authenticated users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow read/write access to companies collection for authenticated users
    match /companies/{companyId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == resource.data.ownerId || 
         request.auth.token.email in resource.data.employees);
    }
    
    // Allow read/write access to company_employees collection
    match /company_employees/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Allow read/write access to suppliers collection based on company membership
    match /suppliers/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to products collection based on company membership
    match /products/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to product_definitions collection based on company membership
    match /product_definitions/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to stock_details collection
    match /stock_details/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to purchase_requests collection
    match /purchase_requests/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to purchase_orders collection
    match /purchase_orders/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to expenses collection
    match /expenses/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to invoices collection
    match /invoices/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to clients collection
    match /clients/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to payments collection
    match /payments/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to chat_messages collection
    match /chat_messages/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
    
    // Allow read/write access to purchase_records collection
    match /purchase_records/{document} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        (get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.ownerId == request.auth.uid ||
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.employees);
    }
  }
}
